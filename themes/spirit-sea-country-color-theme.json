    "panelTitle.activeForeground": "#6fe8dc",
    "panelTitle.activeBorder": "#2ec6d8",
    "panelTitle.inactiveForeground": "#6d8894",

    "terminal.background": "#08151d",
    "terminal.foreground": "#c8dfe8",
