    "//10": "===== Popups / Misc =====",
    "editorWidget.background": "#0c1e28",
    "editorWidget.border": "#21414d",
    "editorSuggestWidget.background": "#0c1e28",
    "editorSuggestWidget.border": "#21414d",
    "editorSuggestWidget.selectedBackground": "#123240",
    "editorSuggestWidget.highlightForeground": "#2ec6d8",
    "editorHoverWidget.background": "#0c1e28",
    "editorHoverWidget.border": "#21414d",
    "peekView.border": "#2ec6d8",
    "peekViewEditor.background": "#08151d",
    "peekViewResult.background": "#071219",
    "peekViewResult.selectionBackground": "#123240",
    "notifications.background": "#0c1e28",
    "notifications.border": "#21414d",
    "notificationCenterHeader.background": "#071219",
    "menu.background": "#0c1e28",
    "menu.foreground": "#c8dfe8",
    "menu.selectionBackground": "#123240",
    "menu.selectionForeground": "#6fe8dc",
    "menu.border": "#21414d",
    "pickerGroup.foreground": "#6fe8dc",
    "pickerGroup.border": "#21414d",
    "breadcrumb.foreground": "#6d8894",
    "breadcrumb.focusForeground": "#6fe8dc",
    "breadcrumb.activeSelectionForeground": "#6fe8dc",
    "textLink.foreground": "#55b3f2",
    "textLink.activeForeground": "#74c4f6"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5c7f8c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#4fd6a0"
      }
    },
    {
      "name": "String escapes / templates",
      "scope": [
        "constant.character.escape",
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#6fe8dc"
      }
    },
    {
      "name": "Numbers / constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ffce5c"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#2ec6d8"
      }
    },
    {
      "name": "Operators / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7a9ba8"
      }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#55b3f2"
      }
    },
    {
      "name": "Types / classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#ff8266"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#c8dfe8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#a6c4d0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language / built-in variables",
      "scope": [
        "variable.language",
        "support.variable",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#ffce5c"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7fdcd0"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#2ec6d8"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ff8266",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS selectors / classes",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#ff8266"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#7fdcd0"
      }
    },
    {
      "name": "Markup headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#2ec6d8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#55b3f2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#4fd6a0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#6fe8dc",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup code / quote",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7fdcd0"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#ffce5c"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff6b5c"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#4fd6a0"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#ff6b5c"
      }
    }
  ]
}
