    "scrollbarSlider.activeBackground": "#2ec6d888",
    "minimap.findMatchHighlight": "#2ec6d8",
    "minimap.selectionHighlight": "#1a4a5c",

    "//8": "===== Panels / Terminal =====",
    "panel.background": "#08151d",
