    "inputOption.activeBorder": "#57c98a",
    "inputOption.activeBackground": "#57c98a33",
    "inputValidation.errorBackground": "#3a1a14",
    "inputValidation.errorBorder": "#e0664d",
    "dropdown.background": "#16201a",
    "dropdown.foreground": "#c6d2c2",
    "dropdown.border": "#2c3a2e",

    "button.background": "#57c98a",
    "button.foreground": "#0e1410",
    "button.hoverBackground": "#6fdb9e",
    "button.secondaryBackground": "#1f2e23",
    "button.secondaryForeground": "#c6d2c2",

    "badge.background": "#4fd6c0",
    "badge.foreground": "#0e1410",
    "progressBar.background": "#57c98a",

    "//7": "===== Scrollbar =====",
    "scrollbar.shadow": "#00000066",
    "scrollbarSlider.background": "#4a584a66",
    "scrollbarSlider.hoverBackground": "#4a584a99",
    "scrollbarSlider.activeBackground": "#57c98a88",
    "minimap.findMatchHighlight": "#57c98a",
    "minimap.selectionHighlight": "#2a4a38",

    "//8": "===== Panels / Terminal =====",
    "panel.background": "#101712",
    "panel.border": "#23311f",
    "panelTitle.activeForeground": "#cfe05a",
    "panelTitle.activeBorder": "#57c98a",
    "panelTitle.inactiveForeground": "#7a8878",

    "terminal.background": "#101712",
    "terminal.foreground": "#c6d2c2",
    "terminalCursor.foreground": "#57c98a",
    "terminal.ansiBlack": "#0e1410",
    "terminal.ansiRed": "#e0664d",
    "terminal.ansiGreen": "#57c98a",
    "terminal.ansiYellow": "#e3d24a",
    "terminal.ansiBlue": "#4fd6c0",
    "terminal.ansiMagenta": "#9bd35a",
    "terminal.ansiCyan": "#4fd6c0",
    "terminal.ansiWhite": "#c6d2c2",
    "terminal.ansiBrightBlack": "#5a685a",
    "terminal.ansiBrightRed": "#f07a62",
    "terminal.ansiBrightGreen": "#6fdb9e",
