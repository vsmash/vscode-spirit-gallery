    "list.inactiveSelectionBackground": "#19241b",
    "list.inactiveSelectionForeground": "#c6d2c2",
    "list.hoverBackground": "#19241b",
    "list.hoverForeground": "#cfe05a",
    "list.focusBackground": "#1f2e23",
    "list.highlightForeground": "#4fd6c0",
    "list.errorForeground": "#e0664d",
    "list.warningForeground": "#e3d24a",
    "tree.indentGuidesStroke": "#2c3a2e",

    "//4": "===== Tabs =====",
    "editorGroup.border": "#23311f",
    "editorGroupHeader.tabsBackground": "#0e1410",
    "editorGroupHeader.tabsBorder": "#23311f",
    "tab.activeBackground": "#121a15",
    "tab.activeForeground": "#cfe05a",
    "tab.activeBorderTop": "#57c98a",
    "tab.activeBorder": "#121a15",
    "tab.inactiveBackground": "#0e1410",
    "tab.inactiveForeground": "#7a8878",
    "tab.hoverForeground": "#cfe05a",
    "tab.border": "#23311f",
    "tab.unfocusedActiveForeground": "#abb8a7",

    "//5": "===== Status bar =====",
    "statusBar.background": "#0e1410",
    "statusBar.foreground": "#abb8a7",
