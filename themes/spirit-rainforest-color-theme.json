    "statusBar.noFolderBackground": "#0e1410",
    "statusBar.debuggingBackground": "#57c98a",
    "statusBar.debuggingForeground": "#0e1410",
    "statusBarItem.remoteBackground": "#4fd6c0",
    "statusBarItem.remoteForeground": "#0e1410",
