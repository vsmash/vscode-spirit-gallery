    "terminal.ansiBrightCyan": "#74e3d4",
    "terminal.ansiBrightWhite": "#e6efe2",

    "//9": "===== Diff / Git =====",
    "diffEditor.insertedTextBackground": "#57c98a22",
    "diffEditor.removedTextBackground": "#e0664d22",
    "gitDecoration.modifiedResourceForeground": "#cfe05a",
    "gitDecoration.deletedResourceForeground": "#e0664d",
    "gitDecoration.untrackedResourceForeground": "#57c98a",
    "gitDecoration.ignoredResourceForeground": "#5a685a",
    "gitDecoration.conflictingResourceForeground": "#e3d24a",

    "//10": "===== Popups / Misc =====",
    "editorWidget.background": "#16201a",
    "editorWidget.border": "#2c3a2e",
    "editorSuggestWidget.background": "#16201a",
    "editorSuggestWidget.border": "#2c3a2e",
    "editorSuggestWidget.selectedBackground": "#1f2e23",
    "editorSuggestWidget.highlightForeground": "#4fd6c0",
    "editorHoverWidget.background": "#16201a",
    "editorHoverWidget.border": "#2c3a2e",
    "peekView.border": "#57c98a",
    "peekViewEditor.background": "#101712",
    "peekViewResult.background": "#0e1410",
    "peekViewResult.selectionBackground": "#1f2e23",
    "notifications.background": "#16201a",
    "notifications.border": "#2c3a2e",
    "notificationCenterHeader.background": "#0e1410",
    "menu.background": "#16201a",
    "menu.foreground": "#c6d2c2",
    "menu.selectionBackground": "#1f2e23",
    "menu.selectionForeground": "#cfe05a",
    "menu.border": "#2c3a2e",
    "pickerGroup.foreground": "#cfe05a",
    "pickerGroup.border": "#2c3a2e",
    "breadcrumb.foreground": "#7a8878",
    "breadcrumb.focusForeground": "#cfe05a",
    "breadcrumb.activeSelectionForeground": "#cfe05a",
    "textLink.foreground": "#4fd6c0",
    "textLink.activeForeground": "#74e3d4"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5f7560",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#9bd35a"
      }
    },
    {
      "name": "String escapes / templates",
      "scope": [
        "constant.character.escape",
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#4fd6c0"
      }
    },
    {
      "name": "Numbers / constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#e3d24a"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#57c98a"
      }
    },
    {
      "name": "Operators / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#8a9a86"
      }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#4fd6c0"
      }
    },
    {
      "name": "Types / classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#cfe05a"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#c6d2c2"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#aebfa6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language / built-in variables",
      "scope": [
        "variable.language",
        "support.variable",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#e3d24a"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#8fdccb"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#57c98a"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#cfe05a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS selectors / classes",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#cfe05a"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#8fdccb"
      }
    },
    {
      "name": "Markup headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#57c98a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#cfe05a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#9bd35a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#4fd6c0",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup code / quote",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.quote"
      ],
      "settings": {
        "foreground": "#8fdccb"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#e3d24a"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e0664d"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#57c98a"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#e0664d"
      }
    }
  ]
}
