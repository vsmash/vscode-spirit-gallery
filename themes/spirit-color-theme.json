    "terminal.ansiBrightCyan": "#7ce0d3",
    "terminal.ansiBrightWhite": "#f2ede4",

    "//9": "===== Diff / Git =====",
    "diffEditor.insertedTextBackground": "#4ec9b022",
    "diffEditor.removedTextBackground": "#e0533d22",
    "gitDecoration.modifiedResourceForeground": "#d9a441",
    "gitDecoration.deletedResourceForeground": "#e0533d",
    "gitDecoration.untrackedResourceForeground": "#4ec9b0",
    "gitDecoration.ignoredResourceForeground": "#6a625a",
    "gitDecoration.conflictingResourceForeground": "#f0883e",

    "//10": "===== Popups / Misc =====",
    "editorWidget.background": "#211e1a",
    "editorWidget.border": "#3a352f",
    "editorSuggestWidget.background": "#211e1a",
    "editorSuggestWidget.border": "#3a352f",
    "editorSuggestWidget.selectedBackground": "#2b2722",
    "editorSuggestWidget.highlightForeground": "#5fd3c4",
    "editorHoverWidget.background": "#211e1a",
    "editorHoverWidget.border": "#3a352f",
    "peekView.border": "#f0883e",
    "peekViewEditor.background": "#1a1815",
    "peekViewResult.background": "#161412",
    "peekViewResult.selectionBackground": "#2b2722",
    "notifications.background": "#211e1a",
    "notifications.border": "#3a352f",
    "notificationCenterHeader.background": "#161412",
    "menu.background": "#211e1a",
    "menu.foreground": "#d6cfc4",
    "menu.selectionBackground": "#2b2722",
    "menu.selectionForeground": "#f0c040",
    "menu.border": "#3a352f",
    "pickerGroup.foreground": "#e8c14a",
    "pickerGroup.border": "#3a352f",
    "breadcrumb.foreground": "#8a7d6b",
    "breadcrumb.focusForeground": "#e8c14a",
    "breadcrumb.activeSelectionForeground": "#f0c040",
    "textLink.foreground": "#5fd3c4",
    "textLink.activeForeground": "#7ce0d3"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8a7d6b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#e3b44a"
      }
    },
    {
      "name": "String escapes / templates",
      "scope": [
        "constant.character.escape",
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#5fd3c4"
      }
    },
    {
      "name": "Numbers / constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other"
      ],
      "settings": {
        "foreground": "#e0772e"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f0883e"
      }
    },
    {
      "name": "Operators / punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#a89e8e"
      }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#5fd3c4"
      }
    },
    {
      "name": "Types / classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#f0c040"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#d6cfc4"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c4bdb0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language / built-in variables",
      "scope": [
        "variable.language",
        "support.variable",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#e0772e"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#9fd9c9"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#f0883e"
      }
    },
    {
      "name": "HTML/XML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e8c14a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS selectors / classes",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#f0c040"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#9fd9c9"
      }
    },
    {
      "name": "Markup headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#f0883e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#e8c14a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#e3b44a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#5fd3c4",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup code / quote",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.quote"
      ],
      "settings": {
        "foreground": "#9fd9c9"
      }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#d9a441"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e0533d"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#4ec9b0"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#e0533d"
      }
    }
  ]
}
