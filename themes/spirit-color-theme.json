    "inputValidation.errorBackground": "#5a1f16",
    "inputValidation.errorBorder": "#e0533d",
    "dropdown.background": "#211e1a",
    "dropdown.foreground": "#d6cfc4",
    "dropdown.border": "#3a352f",

    "button.background": "#d9622e",
    "button.foreground": "#1c1a17",
