    "progressBar.background": "#f0883e",

    "//7": "===== Scrollbar =====",
    "scrollbar.shadow": "#00000066",
    "scrollbarSlider.background": "#57514a66",
    "scrollbarSlider.hoverBackground": "#57514a99",
    "scrollbarSlider.activeBackground": "#f0883e88",
    "minimap.findMatchHighlight": "#d9622e",
    "minimap.selectionHighlight": "#4a3a28",

    "//8": "===== Panels / Terminal =====",
    "panel.background": "#1a1815",
    "panel.border": "#2e2a25",
    "panelTitle.activeForeground": "#f0c040",
    "panelTitle.activeBorder": "#f0883e",
    "panelTitle.inactiveForeground": "#8a7d6b",

    "terminal.background": "#1a1815",
    "terminal.foreground": "#d6cfc4",
    "terminalCursor.foreground": "#f0883e",
    "terminal.ansiBlack": "#161412",
    "terminal.ansiRed": "#e0533d",
    "terminal.ansiGreen": "#4ec9b0",
    "terminal.ansiYellow": "#e8c14a",
    "terminal.ansiBlue": "#5fd3c4",
    "terminal.ansiMagenta": "#d9622e",
    "terminal.ansiCyan": "#5fd3c4",
    "terminal.ansiWhite": "#cfc9c0",
    "terminal.ansiBrightBlack": "#6a625a",
    "terminal.ansiBrightRed": "#f0735d",
