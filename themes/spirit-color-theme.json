    "list.inactiveSelectionForeground": "#d6cfc4",
    "list.hoverBackground": "#24211d",
    "list.hoverForeground": "#e8c14a",
    "list.focusBackground": "#2b2722",
    "list.highlightForeground": "#5fd3c4",
    "list.errorForeground": "#e0533d",
    "list.warningForeground": "#e8c14a",
    "tree.indentGuidesStroke": "#3a352f",

    "//4": "===== Tabs =====",
    "editorGroup.border": "#2e2a25",
