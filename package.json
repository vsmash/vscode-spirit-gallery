{
  "name": "spirit-theme",
  "displayName": "Spirit Gallery",
  "description": "VS Code themes inspired by Aboriginal art at the Spirit Gallery Store, the Argyle Centre, The Rocks, Sydney — warm ochre (Spirit Gallery, Rainforest) and Sea Country reef-blues (dark + light), with orange, yellow, aqua and coral accents.",
  "version": "1.0.8",
  "publisher": "velvary",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vsmash/vscode-spirit-gallery.git"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "aboriginal",
    "ochre",
    "warm",
    "dark",
    "light",
    "reef",
    "aqua",
    "sea country",
    "ocean"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Spirit Gallery",
        "uiTheme": "vs-dark",
        "path": "./themes/spirit-color-theme.json"
      },
      {
        "label": "Spirit Gallery Rainforest",
        "uiTheme": "vs-dark",
        "path": "./themes/spirit-rainforest-color-theme.json"
      },
      {
        "label": "Spirit Gallery Sea Country",
        "uiTheme": "vs-dark",
        "path": "./themes/spirit-sea-country-color-theme.json"
      },
      {
        "label": "Spirit Gallery Sea Country Light",
        "uiTheme": "vs",
        "path": "./themes/spirit-sea-country-light-color-theme.json"
      }
    ]
  }
}
