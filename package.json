  "version": "1.0.6",
  "publisher": "velvary",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/vsmash/vscode-spirit-gallery.git"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "dark",
    "theme",
    "aboriginal",
    "ochre",
    "warm"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Spirit Gallery",
        "uiTheme": "vs-dark",
        "path": "./themes/spirit-color-theme.json"
      },
      {
        "label": "Spirit Gallery Rainforest",
        "uiTheme": "vs-dark",
        "path": "./themes/spirit-rainforest-color-theme.json"
